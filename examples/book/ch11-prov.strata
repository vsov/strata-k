% The `Prov` annotation asks for full provenance: every derived fact carries
% its pedigree — the minimal sets of soft facts it rests on — captured during
% evaluation, compiled to a circuit (режим B), counted exactly by WMC.
domain firm.
pred owns(firm, firm): Bool.
pred controls(firm, firm): Prov.
0.9 :: owns(acme, shell).
0.8 :: owns(shell, target).
0.3 :: owns(acme, target).
controls(X, Y) :- owns(X, Y).
controls(X, Z) :- owns(X, Y), owns(Y, Z).
