{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Program",
  "description": "A whole program document. Carries its `ir_version` (D2/D11).",
  "type": "object",
  "required": [
    "ir_version",
    "items"
  ],
  "properties": {
    "ir_version": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Item"
      }
    }
  },
  "definitions": {
    "AggOp": {
      "description": "Aggregate operators (spec 1.3). Pure-unit enum → bare string (rule 3).",
      "type": "string",
      "enum": [
        "min",
        "max",
        "sum",
        "count",
        "prob_or"
      ]
    },
    "Annotation": {
      "description": "Annotation (semiring / provenance) type. [spec 1.7]\n\nPure-payload variants use adjacent tagging; the unit variants serialize as `{\"kind\":\"bool\"}` etc. Coercion order: `Bool ⊑ Trop`, `Bool ⊑ Prov`, `Prov ⊑ Prov_k`. **`Trop` and `Prov` are incomparable.**",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "bool"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "trop"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "prov"
              ]
            }
          }
        },
        {
          "description": "Top-k provenance approximation; mandatory under recursive soft deps.",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "k"
              ],
              "properties": {
                "k": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0.0
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "prov_k"
              ]
            }
          }
        }
      ]
    },
    "ArgType": {
      "description": "Argument type of one predicate position.\n\nAdjacently tagged (docs/ir-encoding.md rule 2): `{\"kind\":\"domain\",\"data\":{\"name\":\"node\"}}`. The common `domain` case is also accepted as a bare string for LLM ergonomics via [`ArgType`]'s custom handling? — no: kept strict/adjacent for uniformity; the surface sugar lives in the parser, not the IR.",
      "oneOf": [
        {
          "description": "A named constant domain (`.type`-like).",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "domain"
              ]
            }
          }
        },
        {
          "description": "A tropical/numeric weight column, i64 (D6).",
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "int"
              ]
            }
          }
        },
        {
          "description": "Structural term type for `@terms` — present but not executed in Phase 0 (D5).",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "term"
              ]
            }
          }
        }
      ]
    },
    "Atom": {
      "description": "A predicate application. Head aggregates live as [`Term::Agg`] head args.",
      "type": "object",
      "required": [
        "args",
        "pred"
      ],
      "properties": {
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Term"
          }
        },
        "pred": {
          "type": "string"
        }
      }
    },
    "Completeness": {
      "description": "Completeness effect: `sound_only` is set under an active depth bound. [spec 1.4]",
      "type": "string",
      "enum": [
        "complete",
        "sound_only"
      ]
    },
    "Determinism": {
      "description": "Determinism effect: `stochastic` when neural inference with nondeterminism.",
      "type": "string",
      "enum": [
        "deterministic",
        "stochastic"
      ]
    },
    "DomainDecl": {
      "description": "A declared constant domain (`.type`-like).",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "Effects": {
      "description": "The effect triple. Defaults are the strongest guarantees, so an omitted `effects: {}` in JSON means `total`/`complete`/`deterministic`.",
      "type": "object",
      "properties": {
        "completeness": {
          "default": "complete",
          "allOf": [
            {
              "$ref": "#/definitions/Completeness"
            }
          ]
        },
        "determinism": {
          "default": "deterministic",
          "allOf": [
            {
              "$ref": "#/definitions/Determinism"
            }
          ]
        },
        "termination": {
          "default": "total",
          "allOf": [
            {
              "$ref": "#/definitions/Termination"
            }
          ]
        }
      }
    },
    "Fact": {
      "description": "A fact. `weight` present ⇒ tropical; `prob` present ⇒ probabilistic (inert, D5). Both absent ⇒ a plain Bool fact.",
      "type": "object",
      "required": [
        "atom"
      ],
      "properties": {
        "atom": {
          "$ref": "#/definitions/Atom"
        },
        "prob": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "weight": {
          "anyOf": [
            {
              "$ref": "#/definitions/Weight"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "InputDecl": {
      "description": "`input pred from \"file.tsv\"` — Soufflé-compatible TSV EDB (D10).",
      "type": "object",
      "required": [
        "path",
        "pred"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "pred": {
          "type": "string"
        }
      }
    },
    "Item": {
      "description": "A top-level statement plus its attached trivia and source span.\n\n**Equality excludes trivia and span** (IR-5 contract): two `Item`s with the same `node` are equal regardless of comments or source location. The span is clause-level provenance the checker uses to point diagnostics at source.",
      "type": "object",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/DomainDecl"
            },
            "kind": {
              "type": "string",
              "enum": [
                "domain"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/PredDecl"
            },
            "kind": {
              "type": "string",
              "enum": [
                "predicate"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/Rule"
            },
            "kind": {
              "type": "string",
              "enum": [
                "rule"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/Fact"
            },
            "kind": {
              "type": "string",
              "enum": [
                "fact"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/InputDecl"
            },
            "kind": {
              "type": "string",
              "enum": [
                "input"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/Query"
            },
            "kind": {
              "type": "string",
              "enum": [
                "query"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/Pragma"
            },
            "kind": {
              "type": "string",
              "enum": [
                "pragma"
              ]
            }
          }
        }
      ],
      "properties": {
        "span": {
          "$ref": "#/definitions/Span"
        },
        "trivia": {
          "$ref": "#/definitions/Trivia"
        }
      }
    },
    "Literal": {
      "description": "A body literal: positive or (stratified) negated atom. [spec 1.2]",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/Atom"
            },
            "kind": {
              "type": "string",
              "enum": [
                "pos"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/Atom"
            },
            "kind": {
              "type": "string",
              "enum": [
                "neg"
              ]
            }
          }
        }
      ]
    },
    "NeuralSpec": {
      "description": "`neural p(...) from model \"...\"` — parsed, never executed in Phase 0 (D5).",
      "type": "object",
      "required": [
        "model"
      ],
      "properties": {
        "model": {
          "type": "string"
        }
      }
    },
    "Pragma": {
      "description": "A module pragma. `@terms`/`@asp` — parsed, gated as not-implemented (D5).",
      "type": "string",
      "enum": [
        "terms",
        "asp"
      ]
    },
    "PredDecl": {
      "description": "A mandatory predicate declaration (D3): name + signature (+ optional neural binding, inert in Phase 0 per D5).",
      "type": "object",
      "required": [
        "name",
        "sig"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "neural": {
          "anyOf": [
            {
              "$ref": "#/definitions/NeuralSpec"
            },
            {
              "type": "null"
            }
          ]
        },
        "sig": {
          "$ref": "#/definitions/Signature"
        }
      }
    },
    "Query": {
      "description": "A query. `Prob`/`Grad` are parsed but not executed in Phase 0 (D5).",
      "type": "object",
      "required": [
        "atom",
        "kind"
      ],
      "properties": {
        "atom": {
          "$ref": "#/definitions/Atom"
        },
        "kind": {
          "$ref": "#/definitions/QueryKind"
        }
      }
    },
    "QueryKind": {
      "type": "string",
      "enum": [
        "plain",
        "prob",
        "grad"
      ]
    },
    "Rule": {
      "description": "A rule `H :- B1, ..., Bn.`",
      "type": "object",
      "required": [
        "body",
        "head"
      ],
      "properties": {
        "body": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Literal"
          }
        },
        "head": {
          "$ref": "#/definitions/Atom"
        }
      }
    },
    "Signature": {
      "description": "The full three-component signature bound to a predicate. [spec 1.7]",
      "type": "object",
      "required": [
        "annotation",
        "args"
      ],
      "properties": {
        "annotation": {
          "$ref": "#/definitions/Annotation"
        },
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ArgType"
          }
        },
        "effects": {
          "default": {
            "completeness": "complete",
            "determinism": "deterministic",
            "termination": "total"
          },
          "allOf": [
            {
              "$ref": "#/definitions/Effects"
            }
          ]
        }
      }
    },
    "Span": {
      "description": "Byte-offset span into a source (or IR document). [carried from IR-4 node provenance]",
      "type": "object",
      "required": [
        "end",
        "start"
      ],
      "properties": {
        "end": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "start": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "Term": {
      "description": "An argument term.",
      "oneOf": [
        {
          "description": "Uppercase/`_`-leading identifier (Prolog convention, D3).",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "var"
              ]
            }
          }
        },
        {
          "description": "Lowercase identifier — a constant symbol.",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "const"
              ]
            }
          }
        },
        {
          "description": "Integer literal (also a Trop weight source, D6).",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "value"
              ],
              "properties": {
                "value": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "int"
              ]
            }
          }
        },
        {
          "description": "Aggregate head term `agg⟨Var⟩` (spec 1.3).",
          "type": "object",
          "required": [
            "data",
            "kind"
          ],
          "properties": {
            "data": {
              "type": "object",
              "required": [
                "op",
                "var"
              ],
              "properties": {
                "op": {
                  "$ref": "#/definitions/AggOp"
                },
                "var": {
                  "type": "string"
                }
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "agg"
              ]
            }
          }
        }
      ]
    },
    "Termination": {
      "description": "Termination effect. [spec 1.7]",
      "type": "string",
      "enum": [
        "total",
        "partial"
      ]
    },
    "Trivia": {
      "description": "Comments and blank-line hints attached to a node.",
      "type": "object",
      "properties": {
        "blank_before": {
          "description": "Whether a blank line preceded the node (canonical printer may honor it).",
          "type": "boolean"
        },
        "leading": {
          "description": "Comment lines appearing immediately before the node (in source order).",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trailing": {
          "description": "A trailing same-line comment, if any.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Weight": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "const": "inf"
        }
      ]
    }
  }
}
